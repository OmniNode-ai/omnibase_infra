[Unit]
Description=ONEX Overseer Tick — pull Linear backlog, dispatch builders for gaps
Documentation=https://github.com/OmniNode-ai/omnibase_infra
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=%h/.omnibase/.env
ExecStart=/bin/bash %h/Code/omni_home/omnibase_infra/scripts/ticks/overseer-tick.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=onex-tick-overseer

[Install]
WantedBy=default.target
