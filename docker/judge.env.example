# OMN-12924 judge reproducibility inputs.
#
# Policy values come from docker/runtime-policy.env, which is rendered from
# contracts/services/runtime_policy.contract.yaml. This file is only for secrets
# and local credentials a judge must provide without editing source.

POSTGRES_PASSWORD=judge-postgres-password
VALKEY_PASSWORD=judge-valkey-password

# Required for the Gemini demo route. Keep both values explicit; compose guards
# reject nested environment fallbacks so the rendered profile is deterministic.
GEMINI_API_KEY=replace-with-gemini-api-key
GOOGLE_API_KEY=replace-with-gemini-api-key

# Required host skills tree mounted read-only at /app/skills. From the
# omnibase_infra repo root, this workspace-relative path points at the
# OmniMarket Onex skills used by the judge runtime.
OMNICLAUDE_SKILLS_DIR=../omnimarket/plugins/onex/skills

# Optional fallback providers.
OPEN_ROUTER_API_KEY=
LLM_GLM_API_KEY=

# Optional GitHub/Linear effects. Leave empty for local reproduction paths that
# do not create tickets or PRs.
GITHUB_TOKEN=
LINEAR_API_KEY=

# Optional local endpoint hardening knobs. The judge stack defaults to cloud
# Gemini-compatible URLs declared by docker/docker-compose.judge.yml.
LOCAL_LLM_SHARED_SECRET=judge-local-only
LLM_ENDPOINT_CIDR_ALLOWLIST=
